---
// TDRI オリジナルロゴ — 完全独自デザイン
// 「T」を樽（円柱）+ 中央のドットで研究所のメソドロジーを表現
interface Props {
  size?: number;
  variant?: 'light' | 'dark';
}
const { size = 36, variant = 'dark' } = Astro.props;
const fg = variant === 'light' ? '#F8F9F8' : '#0A0A0A';
const accent = '#0E8060';
---

<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="TDRI logo"
  role="img"
>
  <!-- Outer ring (樽 = barrel) -->
  <circle cx="32" cy="32" r="28" stroke={fg} stroke-width="3" />
  <!-- Cross strap (T 横棒) -->
  <line x1="6" y1="20" x2="58" y2="20" stroke={fg} stroke-width="3" />
  <!-- T 縦棒 -->
  <line x1="32" y1="20" x2="32" y2="56" stroke={fg} stroke-width="3" />
  <!-- Accent ドット (研究所 = atom 的ドット) -->
  <circle cx="32" cy="38" r="4" fill={accent} />
</svg>
