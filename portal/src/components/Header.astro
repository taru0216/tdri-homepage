---
import Logo from './Logo.astro';
---

<header
  class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-white/70 border-b border-[var(--color-border)]/60"
>
  <div class="max-w-[80rem] mx-auto px-4 sm:px-6 lg:px-10 h-16 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-3 group">
      <Logo size={32} />
      <div class="leading-tight">
        <div class="font-display text-base text-[var(--color-text)]">TDRI</div>
        <div class="text-[10px] font-mono uppercase tracking-widest text-[var(--color-text-muted)]">
          Taruishi Digital Research Institute
        </div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a class="hover:text-[var(--color-accent)] transition-colors" href="#mission">Mission</a>
      <a class="hover:text-[var(--color-accent)] transition-colors" href="#services">Services</a>
      <a class="hover:text-[var(--color-accent)] transition-colors" href="#works">Works</a>
      <a class="hover:text-[var(--color-accent)] transition-colors" href="#contact">Contact</a>
    </nav>

    <a
      href="#contact"
      class="hidden sm:inline-flex items-center gap-1 px-4 py-2 text-xs font-bold rounded-full bg-[var(--color-bg-ink)] text-white hover:bg-[var(--color-accent-dim)] transition-colors"
    >
      お問い合わせ
      <span aria-hidden="true">→</span>
    </a>
  </div>
</header>
